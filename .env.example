# Required: MCP auth
MCP_BEARER_TOKEN=changeme

# Required: Embedding model file (for bundled llama.cpp)
MODEL_PATH=/path/to/models
MODEL_FILE=nomic-embed-text-v2-moe.gguf

# Optional: webhook (omit to disable webhook endpoint)
# WEBHOOK_SECRET=changeme

# Optional: knowledge base path (default: ./data/repo)
# KB_PATH=./data/repo

# Optional: override connection defaults (set automatically in docker-compose.yml)
# EMBEDDING_BASE_URL=http://embeddings:8080/v1
# EMBEDDING_MODEL=nomic-embed-text-v2-moe
# EMBEDDING_VECTOR_SIZE=768
# QDRANT_URL=http://qdrant:6334
