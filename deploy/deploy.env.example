# Deploy target configuration — copy to deploy.env and customize
# Used by deploy.sh to pull and restart the kb-rag service remotely.

# Absolute path to the docker-compose.yml on the target host
COMPOSE_FILE="/path/to/docker-compose.yml"

# Docker context (blank = local Docker daemon)
DOCKER_CONTEXT=""

# Service name in the compose file
SERVICE="kb-rag"
