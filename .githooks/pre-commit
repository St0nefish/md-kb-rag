#!/bin/sh
# Pre-commit hook: auto-format and lint Rust code

if ! command -v cargo >/dev/null 2>&1; then
    echo "cargo not found, skipping fmt/clippy"
    exit 0
fi

cargo fmt

# Re-stage any files that were reformatted
git diff --name-only | grep '\.rs$' | xargs -r git add

cargo clippy -- -D warnings

# Validate config.example.yaml parses if it was changed
if git diff --cached --name-only | grep -q 'config\.example\.yaml$'; then
  cargo test -q -- config::tests::example_config_deserializes
fi
